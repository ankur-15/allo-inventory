generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A product in the catalog
model Product {
  id           String        @id @default(cuid())
  name         String
  sku          String        @unique
  description  String?
  price        Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  inventory    Inventory[]
  reservations Reservation[]
}

// Physical warehouse location
model Warehouse {
  id           String        @id @default(cuid())
  name         String
  location     String
  createdAt    DateTime      @default(now())
  inventory    Inventory[]
  reservations Reservation[]
}

// How many units of a product sit in a specific warehouse.
// reservedUnits = units currently held by active reservations (not yet paid).
// availableUnits = totalUnits - reservedUnits (computed in code, not stored).
model Inventory {
  id            String    @id @default(cuid())
  productId     String
  warehouseId   String
  totalUnits    Int       @default(0)
  reservedUnits Int       @default(0)
  product       Product   @relation(fields: [productId], references: [id])
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
}

// A reservation ties a customer to specific units for a limited window.
// PENDING  → units held, waiting for payment
// CONFIRMED → payment succeeded, units permanently decremented
// RELEASED → payment failed / cancelled / timed out, units freed
model Reservation {
  id          String            @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int
  status      ReservationStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  product     Product           @relation(fields: [productId], references: [id])
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id])

  @@index([status, expiresAt]) // speeds up the cron expiry query
}

// Stores results of already-processed requests so retried calls
// don't cause double-charges or double-reservations.
model IdempotencyRecord {
  id         String   @id @default(cuid())
  key        String   @unique
  statusCode Int
  body       Json
  createdAt  DateTime @default(now())
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
}